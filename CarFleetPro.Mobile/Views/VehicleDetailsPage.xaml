<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.VehicleDetailsPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" HeightRequest="280">
            <Image Source="clio_large.png" Aspect="AspectFill" />
            <BoxView Color="#000000" Opacity="0.3" />

            <ImageButton Source="arrow_left_white.svg" 
                         Clicked="OnBackClicked"
                         HorizontalOptions="Start" VerticalOptions="Start"
                         Margin="20,50,0,0" HeightRequest="30" WidthRequest="30"/>

            <Border HorizontalOptions="End" VerticalOptions="End" 
                    Margin="0,0,20,20" BackgroundColor="#10B981" Padding="15,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Label x:Name="StatusBadge" Text="MÜSAİT" TextColor="White" FontAttributes="Bold" FontSize="12"/>
            </Border>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-30,0,0">
            <VerticalStackLayout Spacing="20" Padding="20,0,20,30">

                <Border BackgroundColor="White" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding MarkaModel}" FontSize="24" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Label Text="{Binding PlakaYil}" FontSize="16" TextColor="#6B7280"/>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="White" Padding="10" HeightRequest="80">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="KM" FontSize="12" HorizontalOptions="Center" TextColor="#9CA3AF"/>
                            <Label Text="{Binding Km}" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="White" Padding="10" HeightRequest="80">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="KM" FontSize="12" HorizontalOptions="Center" TextColor="#9CA3AF"/>
                            <Label x:Name="KmLabel" Text="0" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Padding="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="YAKIT" FontSize="12" HorizontalOptions="Center" TextColor="#9CA3AF"/>
                            <Label x:Name="FuelLabel" Text="-" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="White" Padding="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="VİTES" FontSize="12" HorizontalOptions="Center" TextColor="#9CA3AF"/>
                            <Label x:Name="GearLabel" Text="-" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="Son Hareketler" FontAttributes="Bold" FontSize="18" Margin="5,10,0,0"/>

                <Border BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                <CollectionView x:Name="HistoryList" VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,7">
                                <BoxView WidthRequest="4" BackgroundColor="{Binding Color}" Grid.Column="0"/>
                                <VerticalStackLayout Grid.Column="1" Margin="15,0">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#1F2937"/>
                                    <Label Text="{Binding DateRange}" FontSize="12" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding Status}" TextColor="#10B981" VerticalOptions="Center" FontSize="12"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                    <Button Grid.Column="0" Text="BAKIMA GÖNDER" Clicked="OnMaintenanceClicked" BackgroundColor="White" TextColor="#F59E0B" BorderColor="#F59E0B" BorderWidth="1" HeightRequest="55" CornerRadius="12" FontAttributes="Bold"/>
                    <Button Grid.Column="1" Text="ARACI KİRALA" Clicked="OnRentClicked" BackgroundColor="#3B82F6" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold"/>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>