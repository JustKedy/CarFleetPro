<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.AdminMenuPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, *, 75">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                    <Label Text="PRO"      FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Text="YÖNETİCİ MENÜSÜ" FontSize="24" TextColor="White"
                       HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <!-- Menu Content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <Label Text="Operasyonel İşlemler" FontSize="18" FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" Margin="0,10,0,5"/>

                <!-- Grid of Menu Items -->
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="15" RowSpacing="15">
                    
                    <!-- Invoices -->
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInvoicesClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#E0F2FE" StrokeThickness="0" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="25"/></Border.StrokeShape>
                                <Label Text="📄" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Faturalar ve&#10;Ödemeler" HorizontalTextAlignment="Center" FontSize="14" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Staff Management -->
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStaffClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#DCFCE7" StrokeThickness="0" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="25"/></Border.StrokeShape>
                                <Label Text="👥" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Personel&#10;Yönetimi" HorizontalTextAlignment="Center" FontSize="14" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Send Notification -->
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSendNotificationClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#FEF3C7" StrokeThickness="0" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="25"/></Border.StrokeShape>
                                <Label Text="🔔" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Bildirim&#10;Gönder" HorizontalTextAlignment="Center" FontSize="14" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Price Policy -->
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPricePolicyClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#FEE2E2" StrokeThickness="0" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="25"/></Border.StrokeShape>
                                <Label Text="💰" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Fiyat ve İndirim&#10;Politikası" HorizontalTextAlignment="Center" FontSize="14" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="20" Margin="0,10,0,0" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Yönetici Notu" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        <Label Text="Bu ekran üzerinden şirket genelindeki tüm finansal ve personelsel süreçleri yönetebilirsiniz. Fiyat politikası değişiklikleri anında kiralama formlarına yansır." 
                               FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="Profile" />

    </Grid>
</ContentPage>
