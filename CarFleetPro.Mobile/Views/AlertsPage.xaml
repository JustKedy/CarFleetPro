<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.AlertsPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, *, 75">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                    <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Text="BİLDİRİM MERKEZİ" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" Margin="20,10" VerticalScrollBarVisibility="Never">
            <CollectionView.Header>
                <Label Text="Bugün İlgi Bekleyenler" FontAttributes="Bold" TextColor="#1F2937" Margin="5,10" />
            </CollectionView.Header>

            <CollectionView.ItemsSource>
            </CollectionView.ItemsSource>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White" Margin="0,5" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.1"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto">
                            <Border Grid.Column="0" Grid.RowSpan="2" WidthRequest="50" HeightRequest="50" 
                                    BackgroundColor="#FEE2E2" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25" />
                                </Border.StrokeShape>
                                <Image Source="bell_on_black.svg" HeightRequest="20" WidthRequest="20" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                <Label Text="GECİKMİŞ İADE" FontSize="12" FontAttributes="Bold" TextColor="#EF4444" />
                                <Label Text="55 MS 061 - Renault Clio" FontAttributes="Bold" TextColor="#1F2937" />
                                <Label Text="Müşteri: Abdulkadir Toksöz" FontSize="12" TextColor="#6B7280" />
                            </VerticalStackLayout>

                            <ImageButton Grid.Column="2" Grid.RowSpan="2" Source="arrow_right_black.svg" 
                                         HeightRequest="25" WidthRequest="25" VerticalOptions="Center" />

                            <Label Grid.Row="1" Grid.Column="1" Text="2 Gündür Gecikmede" 
                                   FontSize="11" TextColor="#EF4444" Margin="15,2,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="Home" />

    </Grid>
</ContentPage>