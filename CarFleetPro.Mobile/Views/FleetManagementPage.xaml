<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             xmlns:vm="clr-namespace:CarFleetPro.Mobile.ViewModels"
             xmlns:models="clr-namespace:CarFleetPro.Mobile.Models"
             x:DataType="vm:FleetManagementViewModel"
             x:Class="CarFleetPro.Mobile.Views.FleetManagementPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0" HeightRequest="110">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold"/>
                    <Label Text="PRO"      FontSize="14" TextColor="#3B82F6" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Text="FİLO DÜZENLE" FontSize="26" TextColor="White"
                       HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="20,15,20,5">
            <HorizontalStackLayout Spacing="10">
                <!-- Tümü -->
                <Border HeightRequest="38" Padding="15,0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                        StrokeThickness="1" 
                        Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="Tümü"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding SeciliFiltre}" Value="Tümü">
                            <Setter Property="BackgroundColor" Value="#3B82F6" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Tümü" VerticalOptions="Center" FontAttributes="Bold" FontSize="13"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding SeciliFiltre}" Value="Tümü">
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Müsait -->
                <Border HeightRequest="38" Padding="15,0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                        StrokeThickness="1" 
                        Stroke="#10B981">
                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="MÜSAİT"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding SeciliFiltre}" Value="MÜSAİT">
                            <Setter Property="BackgroundColor" Value="#10B981" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Ellipse WidthRequest="8" HeightRequest="8" Fill="#10B981">
                            <Ellipse.Triggers>
                                <DataTrigger TargetType="Ellipse" Binding="{Binding SeciliFiltre}" Value="MÜSAİT">
                                    <Setter Property="Fill" Value="White" />
                                </DataTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Label Text="Müsait" FontSize="13" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SeciliFiltre}" Value="MÜSAİT">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </HorizontalStackLayout>
                </Border>

                <!-- Bakımda -->
                <Border HeightRequest="38" Padding="15,0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                        StrokeThickness="1" 
                        Stroke="#F59E0B">
                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="BAKIMDA"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding SeciliFiltre}" Value="BAKIMDA">
                            <Setter Property="BackgroundColor" Value="#F59E0B" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Ellipse WidthRequest="8" HeightRequest="8" Fill="#F59E0B">
                            <Ellipse.Triggers>
                                <DataTrigger TargetType="Ellipse" Binding="{Binding SeciliFiltre}" Value="BAKIMDA">
                                    <Setter Property="Fill" Value="White" />
                                </DataTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Label Text="Bakımda" FontSize="13" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SeciliFiltre}" Value="BAKIMDA">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </HorizontalStackLayout>
                </Border>

                <!-- Dolu -->
                <Border HeightRequest="38" Padding="15,0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                        StrokeThickness="1" 
                        Stroke="#EF4444">
                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="DOLU"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding SeciliFiltre}" Value="DOLU">
                            <Setter Property="BackgroundColor" Value="#EF4444" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Ellipse WidthRequest="8" HeightRequest="8" Fill="#EF4444">
                            <Ellipse.Triggers>
                                <DataTrigger TargetType="Ellipse" Binding="{Binding SeciliFiltre}" Value="DOLU">
                                    <Setter Property="Fill" Value="White" />
                                </DataTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Label Text="Dolu" FontSize="13" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SeciliFiltre}" Value="DOLU">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2">

            <ScrollView VerticalScrollBarVisibility="Never"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding AracListesi}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Vehicle">
                            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Margin="20,10,20,10"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="15">
                                        <Border Grid.Column="0" WidthRequest="60" HeightRequest="60"
                                                BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}" StrokeThickness="0" VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Grid>
                                                <Image Source="{AppThemeBinding Light=car.svg, Dark=carnegatif.svg}" HeightRequest="30" WidthRequest="30"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Image Source="{Binding ResimUrl}" Aspect="AspectFill" />
                                            </Grid>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="2">
                                            <Label FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Marka}"/>
                                                        <Span Text=" "/>
                                                        <Span Text="{Binding Model}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="{Binding Plaka}" FontSize="14" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            <Label Text="{Binding Durum}" FontSize="12" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2" BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}" StrokeThickness="0" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" HorizontalOptions="End">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                            <Button Text="&#8942;"
                                                    Clicked="OnMoreClicked"
                                                    FontSize="20"
                                                    TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                                                    BackgroundColor="Transparent"
                                                    HeightRequest="40" WidthRequest="40"
                                                    Padding="0"
                                                    HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Expandable Menu Area -->
                                    <VerticalStackLayout IsVisible="{Binding IsExpanded}" Padding="15,0,15,15" Spacing="15">
                                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" Margin="0,0,0,5"/>
                                        
                                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                            
                                            <VerticalStackLayout Grid.Column="0" Spacing="5" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=IsAdmin}">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=DuzenleCommand}" CommandParameter="{Binding .}"/>
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Border BackgroundColor="#E0F2FE" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                                    <Image Source="edit.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="Düzenle" FontSize="11" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="5" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=IsAdmin}">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=SilCommand}" CommandParameter="{Binding .}"/>
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Border BackgroundColor="#FEE2E2" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                                    <Image Source="trash.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="Sil" FontSize="11" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnHasarKayitlariClicked"/>
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Border BackgroundColor="#FEF3C7" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                                    <Image Source="alert_triangle.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="Hasar" FontSize="11" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="3" Spacing="5">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnBakimKayitlariClicked"/>
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Border BackgroundColor="#ECFDF5" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                                    <Image Source="history.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="Arıza" FontSize="11" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            </VerticalStackLayout>
                                            
                                        </Grid>

                                        <!-- Hızlı Durum Değiştir -->
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="HIZLI DURUM DEĞİŞTİR" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                                                   CharacterSpacing="1"/>
                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                                                <!-- MÜSAİT -->
                                                <Border Grid.Column="0" StrokeThickness="2" HeightRequest="38">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                                                    <Border.Stroke><SolidColorBrush Color="#10B981"/></Border.Stroke>
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Durum}" Value="MÜSAİT">
                                                            <Setter Property="BackgroundColor" Value="#10B981"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=DurumDegistirCommand}"
                                                            CommandParameter="{Binding Id, StringFormat='{0}|MÜSAİT'}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="✓ Müsait" FontSize="12" FontAttributes="Bold"
                                                           TextColor="#10B981"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Durum}" Value="MÜSAİT">
                                                                <Setter Property="TextColor" Value="White"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Border>

                                                <!-- BAKIMDA -->
                                                <Border Grid.Column="1" StrokeThickness="2" HeightRequest="38">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                                                    <Border.Stroke><SolidColorBrush Color="#F59E0B"/></Border.Stroke>
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Durum}" Value="BAKIMDA">
                                                            <Setter Property="BackgroundColor" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=DurumDegistirCommand}"
                                                            CommandParameter="{Binding Id, StringFormat='{0}|BAKIMDA'}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="🔧 Bakımda" FontSize="12" FontAttributes="Bold"
                                                           TextColor="#F59E0B"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Durum}" Value="BAKIMDA">
                                                                <Setter Property="TextColor" Value="White"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Border>

                                                <!-- DOLU -->
                                                <Border Grid.Column="2" StrokeThickness="2" HeightRequest="38">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                                                    <Border.Stroke><SolidColorBrush Color="#EF4444"/></Border.Stroke>
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Durum}" Value="DOLU">
                                                            <Setter Property="BackgroundColor" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FleetManagementViewModel}}, Path=DurumDegistirCommand}"
                                                            CommandParameter="{Binding Id, StringFormat='{0}|DOLU'}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="🚗 Dolu" FontSize="12" FontAttributes="Bold"
                                                           TextColor="#EF4444"
                                                           HorizontalOptions="Center" VerticalOptions="Center">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Durum}" Value="DOLU">
                                                                <Setter Property="TextColor" Value="White"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Border>

                                            </Grid>
                                        </VerticalStackLayout>

                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout Padding="20,10,20,20" Spacing="15"
                                 IsVisible="{Binding IsLoading}">

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="15">
                        <BoxView Grid.Column="0" HeightRequest="70" WidthRequest="70" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="8"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView HeightRequest="14" WidthRequest="120" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                            <BoxView HeightRequest="11" WidthRequest="80"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                            <BoxView HeightRequest="10" WidthRequest="60"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="15">
                        <BoxView Grid.Column="0" HeightRequest="70" WidthRequest="70" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="8"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView HeightRequest="14" WidthRequest="120" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                            <BoxView HeightRequest="11" WidthRequest="80"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                            <BoxView HeightRequest="10" WidthRequest="60"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="15">
                        <BoxView Grid.Column="0" HeightRequest="70" WidthRequest="70" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="8"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView HeightRequest="14" WidthRequest="120" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                            <BoxView HeightRequest="11" WidthRequest="80"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                            <BoxView HeightRequest="10" WidthRequest="60"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="15">
                        <BoxView Grid.Column="0" HeightRequest="70" WidthRequest="70" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="8"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <BoxView HeightRequest="14" WidthRequest="120" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                            <BoxView HeightRequest="11" WidthRequest="80"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                            <BoxView HeightRequest="10" WidthRequest="60"  BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="5"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </Grid>

        <Button Grid.Row="3"
                Text="YENİ ARAÇ EKLE"
                Clicked="OnAddNewVehicleClicked"
                BackgroundColor="#3B82F6"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="12"
                HeightRequest="55"
                Margin="20,10,20,15"
                IsVisible="{Binding IsAdmin}"/>


        <controls:BottomNavBar Grid.Row="4" SelectedTab="List"/>

    </Grid>
</ContentPage>