<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.FleetManagementPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto">

        <Border Grid.Row="0"
                BackgroundColor="#0A1128" 
                StrokeThickness="0"
                HeightRequest="110">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>

            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                    <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Text="FİLO DÜZENLE" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="15,15,0,5">
            <HorizontalStackLayout Spacing="10">
                <Button Text="Tümü" BackgroundColor="#0A1128" TextColor="White" CornerRadius="20" HeightRequest="40" Padding="15,0" />
                <Button Text="Müsait" BackgroundColor="White" TextColor="#1F2937" BorderColor="#D1D5DB" BorderWidth="1" CornerRadius="20" HeightRequest="40" Padding="15,0" />
                <Button Text="Bakımda" BackgroundColor="White" TextColor="#1F2937" BorderColor="#D1D5DB" BorderWidth="1" CornerRadius="20" HeightRequest="40" Padding="15,0" />
                <Button Text="Dolu" BackgroundColor="White" TextColor="#1F2937" BorderColor="#D1D5DB" BorderWidth="1" CornerRadius="20" HeightRequest="40" Padding="15,0" />
            </HorizontalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="2" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="0">

                <Border BackgroundColor="White" Padding="15" Margin="20, 10, 20, 10" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" BackgroundColor="#F3F4F6" StrokeThickness="0" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Image Source="car.svg" HeightRequest="35" WidthRequest="35" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="2">
                            <Label Text="RENAULT CLIO" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" />
                            <Label Text="55 5MS 34" FontSize="14" TextColor="#4B5563" />
                            <Label Text="Araç Marka" FontSize="12" TextColor="#9CA3AF" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                            <Image Source="edit.svg" HeightRequest="22" WidthRequest="22" />
                            <Image Source="trash.svg" HeightRequest="22" WidthRequest="22" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="White" Padding="15" Margin="20, 10, 20, 10" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" BackgroundColor="#F3F4F6" StrokeThickness="0" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Image Source="car.svg" HeightRequest="35" WidthRequest="35" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="2">
                            <Label Text="FORD FOCUS" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" />
                            <Label Text="34 ABC 123" FontSize="14" TextColor="#4B5563" />
                            <Label Text="Araç Marka" FontSize="12" TextColor="#9CA3AF" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                            <Image Source="edit.svg" HeightRequest="22" WidthRequest="22" />
                            <Image Source="trash.svg" HeightRequest="22" WidthRequest="22" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="3" 
                Text="YENİ ARAÇ EKLE" 
                Clicked="OnAddNewVehicleClicked"
                BackgroundColor="#3B82F6" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="12" 
                HeightRequest="55"
                Margin="20,10,20,15" />

        <controls:BottomNavBar Grid.Row="4" SelectedTab="List" />

    </Grid>
</ContentPage>