<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.ChangePasswordPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="110, *">
        
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="ŞİFRE DEĞİŞTİR" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Şifre Bilgilerini Güncelle" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" Margin="0,0,0,5"/>

                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="OldPasswordEntry" Placeholder="Mevcut Şifre" IsPassword="True" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                        </Border>

                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="NewPasswordEntry" Placeholder="Yeni Şifre" IsPassword="True" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent" TextChanged="OnNewPasswordTextChanged" />
                        </Border>

                        <!-- YUNUS İÇİN NOT: Şifre girildikçe BoxView renklerini değiştir (Kırmızı/Sarı/Yeşil) -->
                        <VerticalStackLayout Spacing="5" Margin="0,-5,0,5">
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="5" HeightRequest="4">
                                <BoxView x:Name="Strength1" Grid.Column="0" BackgroundColor="#E5E7EB" CornerRadius="2"/>
                                <BoxView x:Name="Strength2" Grid.Column="1" BackgroundColor="#E5E7EB" CornerRadius="2"/>
                                <BoxView x:Name="Strength3" Grid.Column="2" BackgroundColor="#E5E7EB" CornerRadius="2"/>
                            </Grid>
                            <Label x:Name="StrengthLabel" Text="Şifre gücü bekleniyor..." FontSize="11" TextColor="#6B7280" HorizontalOptions="End"/>
                        </VerticalStackLayout>


                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="ConfirmPasswordEntry" Placeholder="Yeni Şifre (Tekrar)" IsPassword="True" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Button Text="ŞİFREYİ GÜNCELLE" Clicked="OnChangePasswordClicked" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="55" Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
