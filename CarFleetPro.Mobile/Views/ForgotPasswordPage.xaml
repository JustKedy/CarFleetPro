<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.ForgotPasswordPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0A1128}"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Image Source="{AppThemeBinding Light=lock_black.svg, Dark=lock_white.svg}" HeightRequest="80" HorizontalOptions="Center" />

        <Label Text="Şifrenizi mi Unuttunuz?" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" />

        <Label Text="Kayıtlı e-posta adresinizi girin, size bir sıfırlama kodu gönderelim." 
               HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" />

        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" HeightRequest="55">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Entry x:Name="EmailEntry" Placeholder="E-posta Adresi" Keyboard="Email" Margin="15,0" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" />
        </Border>

        <Button Text="KOD GÖNDER" Clicked="OnSendCodeClicked" BackgroundColor="#3B82F6" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold" />

        <Label Text="Giriş Ekranına Dön" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" TextDecorations="Underline">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>
</ContentPage>
