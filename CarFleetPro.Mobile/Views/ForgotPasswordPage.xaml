<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.ForgotPasswordPage"
             BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="30,50,30,30" Spacing="0">

            <!-- Logo -->
            <Border WidthRequest="80" HeightRequest="80" StrokeThickness="0"
                    BackgroundColor="#0A1128" HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <Image Source="{AppThemeBinding Light=lock_white.svg, Dark=lock_white.svg}"
                       HeightRequest="38" WidthRequest="38"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Label Margin="0,20,0,4" HorizontalOptions="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="CARFLEET" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=White}"/>
                        <Span Text="PRO" FontSize="20" FontAttributes="Bold" TextColor="#3B82F6"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label x:Name="PageTitle" Text="Şifrenizi mi Unuttunuz?"
                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                   Margin="0,0,0,8"/>

            <Label x:Name="PageSubtitle"
                   Text="Kayıtlı e-posta adresinizi girin, 6 haneli doğrulama kodu gönderelim."
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"
                   FontSize="14" Margin="0,0,0,32"/>

            <!-- ADIM GÖSTERGESİ -->
            <Grid ColumnDefinitions="*,Auto,*,Auto,*" HorizontalOptions="Center"
                  WidthRequest="240" Margin="0,0,0,32">
                <!-- Step 1 -->
                <Border Grid.Column="0" HeightRequest="32" WidthRequest="32"
                        StrokeThickness="0" HorizontalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Source={x:Reference StepIndicator1}, Path=IsVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#3B82F6"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label x:Name="StepIndicator1" Text="1" TextColor="White" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <BoxView Grid.Column="1" HeightRequest="2" WidthRequest="30" VerticalOptions="Center"
                         BackgroundColor="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"/>
                <!-- Step 2 -->
                <Border Grid.Column="2" HeightRequest="32" WidthRequest="32"
                        StrokeThickness="2" Stroke="#3B82F6" HorizontalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <Label x:Name="StepIndicator2" Text="2" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <BoxView Grid.Column="3" HeightRequest="2" WidthRequest="30" VerticalOptions="Center"
                         BackgroundColor="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"/>
                <!-- Step 3 -->
                <Border Grid.Column="4" HeightRequest="32" WidthRequest="32"
                        StrokeThickness="2" Stroke="#3B82F6" HorizontalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <Label x:Name="StepIndicator3" Text="3" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- ═══════════════ ADIM 1: E-POSTA ═══════════════ -->
            <VerticalStackLayout x:Name="Step1Panel" Spacing="16">

                <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                        StrokeThickness="1.5"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        HeightRequest="55">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" Padding="14,0">
                        <Image Grid.Column="0" Source="{AppThemeBinding Light=email_black.svg, Dark=email_white.svg}"
                               HeightRequest="20" WidthRequest="20" VerticalOptions="Center"/>
                        <Entry x:Name="EmailEntry" Grid.Column="1" Margin="10,0,0,0"
                               Placeholder="E-posta Adresiniz" Keyboard="Email"
                               TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                    </Grid>
                </Border>

                <Button x:Name="SendCodeButton"
                        Text="DOĞRULAMA KODU GÖNDER"
                        Clicked="OnSendCodeClicked"
                        BackgroundColor="#3B82F6" TextColor="White"
                        HeightRequest="55" CornerRadius="14"
                        FontAttributes="Bold" FontSize="15"/>

            </VerticalStackLayout>

            <!-- ═══════════════ ADIM 2: KOD DOĞRULAMA ═══════════════ -->
            <VerticalStackLayout x:Name="Step2Panel" Spacing="16" IsVisible="False">

                <Label Text="E-postanıza gelen 6 haneli kodu girin."
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"
                       FontSize="14"/>

                <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                        StrokeThickness="1.5"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        HeightRequest="65">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Entry x:Name="OtpEntry"
                           Placeholder="● ● ● ● ● ●"
                           Keyboard="Numeric" MaxLength="6"
                           FontSize="22" FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                           PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                           Margin="14,0"/>
                </Border>

                <Button Text="KODU DOĞRULA"
                        Clicked="OnVerifyCodeClicked"
                        BackgroundColor="#3B82F6" TextColor="White"
                        HeightRequest="55" CornerRadius="14"
                        FontAttributes="Bold" FontSize="15"/>

                <Label Text="Kodu almadım — Yeniden gönder"
                       HorizontalOptions="Center"
                       TextColor="#3B82F6"
                       TextDecorations="Underline"
                       FontSize="13">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResendCodeTapped"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

            <!-- ═══════════════ ADIM 3: YENİ ŞİFRE ═══════════════ -->
            <VerticalStackLayout x:Name="Step3Panel" Spacing="16" IsVisible="False">

                <Label Text="Güçlü bir yeni şifre belirleyin (min. 6 karakter)."
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"
                       FontSize="14"/>

                <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                        StrokeThickness="1.5"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        HeightRequest="55">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Entry x:Name="NewPasswordEntry"
                           Placeholder="Yeni Şifre" IsPassword="True"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                           PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                           Margin="14,0"/>
                </Border>

                <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                        StrokeThickness="1.5"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        HeightRequest="55">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Entry x:Name="ConfirmPasswordEntry"
                           Placeholder="Yeni Şifreyi Onayla" IsPassword="True"
                           TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                           PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                           Margin="14,0"/>
                </Border>

                <Button Text="ŞİFREYİ SIFIRLA"
                        Clicked="OnResetPasswordClicked"
                        BackgroundColor="#10B981" TextColor="White"
                        HeightRequest="55" CornerRadius="14"
                        FontAttributes="Bold" FontSize="15"/>

            </VerticalStackLayout>

            <!-- Giriş ekranına dön -->
            <Label Text="← Giriş Ekranına Dön"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                   TextDecorations="Underline"
                   FontSize="13" Margin="0,24,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackToLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
