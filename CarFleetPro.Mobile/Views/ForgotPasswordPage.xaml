<VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
    <Image Source="lock_white.svg" HeightRequest="80" HorizontalOptions="Center" />
    <Label Text="Şifrenizi mi Unuttunuz?" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
    <Label Text="Kayıtlı e-posta adresinizi girin, size bir sıfırlama kodu gönderelim." 
           HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="#6B7280" />

    <Border Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="White" HeightRequest="55">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12" />
        </Border.StrokeShape>
        <Entry Placeholder="E-posta Adresi" Keyboard="Email" Margin="15,0" />
    </Border>

    <Button Text="KOD GÖNDER" BackgroundColor="#3B82F6" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold" />
    <Label Text="Giriş Ekranına Dön" HorizontalOptions="Center" TextDecorations="Underline">
        <Label.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
        </Label.GestureRecognizers>
    </Label>
</VerticalStackLayout>