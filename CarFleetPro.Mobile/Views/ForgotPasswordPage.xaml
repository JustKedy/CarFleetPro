<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.ForgotPasswordPage"
             BackgroundColor="#0A1128"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Image Source="lock_white.svg" HeightRequest="80" HorizontalOptions="Center" />

        <Label Text="Şifrenizi mi Unuttunuz?" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />

        <Label Text="Kayıtlı e-posta adresinizi girin, size bir sıfırlama kodu gönderelim." 
               HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="#9CA3AF" />

        <Border Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="White" HeightRequest="55">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Entry x:Name="EmailEntry" Placeholder="E-posta Adresi" Keyboard="Email" Margin="15,0" TextColor="#1F2937" />
        </Border>

        <Button Text="KOD GÖNDER" Clicked="OnSendCodeClicked" BackgroundColor="#3B82F6" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold" />

        <Label Text="Giriş Ekranına Dön" HorizontalOptions="Center" TextColor="#9CA3AF" TextDecorations="Underline">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>
</ContentPage>