<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.DamageRecordPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Border BackgroundColor="#0A1128" StrokeThickness="0" Padding="0,0,0,25">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,30,30"/>
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto, Auto, Auto">
                    <!-- Top Nav -->
                    <Grid Grid.Row="0" HeightRequest="75" Padding="20,10,20,0">
                        <ImageButton Source="arrow_back_white.svg"
                                     Clicked="OnBackClicked"
                                     BackgroundColor="Transparent"
                                     WidthRequest="30" HeightRequest="30"
                                     HorizontalOptions="Start" VerticalOptions="Center"/>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                                <Label Text="CARFLEET" FontSize="13" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="PRO"      FontSize="13" TextColor="#EF4444" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                            <Label Text="HASAR KAYITLARI" FontSize="22" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Araç Resmi -->
                    <Border Grid.Row="1" Margin="20,10,20,0" StrokeThickness="0" HeightRequest="190">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Grid>
                            <Image x:Name="AracResim" Aspect="AspectFill" HeightRequest="190"/>
                            <!-- Karartma -->
                            <BoxView BackgroundColor="#00000066" CornerRadius="16"/>
                        </Grid>
                    </Border>

                    <!-- Araç Adı & Plaka -->
                    <VerticalStackLayout Grid.Row="2" Margin="0,12,0,0" Spacing="3">
                        <Label x:Name="AracAdLabel"
                               Text="- -"
                               TextColor="White" FontSize="22" FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label x:Name="AracPlakaLabel"
                               Text="-"
                               TextColor="#EF4444" FontSize="14"
                               HorizontalOptions="Center" Opacity="0.9"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Form -->
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Araç Özeti -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        Padding="16" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08"/></Border.Shadow>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                            <Label Text="Marka / Model" FontSize="11" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                            <Label x:Name="MarkaModelLabel" Text="-" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2" HorizontalOptions="End">
                            <Label Text="Kilometre" FontSize="11" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" HorizontalOptions="End"/>
                            <Label x:Name="KmLabel" Text="-" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                            <Label Text="Yıl" FontSize="11" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                            <Label x:Name="YilLabel" Text="-" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2" HorizontalOptions="End">
                            <Label Text="Durum" FontSize="11" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" HorizontalOptions="End"/>
                            <Label x:Name="DurumLabel" Text="-" FontSize="14" FontAttributes="Bold"
                                   TextColor="#EF4444" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Hasar Bilgileri Başlık -->
                <Label Text="Hasar Bilgileri" FontSize="17" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" Margin="0,5,0,0"/>

                <!-- Hasar Türü -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Hasar Türü / Tipi" FontSize="12"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                    <Border HeightRequest="52" Padding="15,0" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Entry x:Name="HasarTuruEntry"
                               Placeholder="Ör: Çarpışma, Çizik, Cam Kırılması..."
                               TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Tarih & Maliyet -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Hasar Tarihi" FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                        <Border HeightRequest="52" Padding="10,0" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <DatePicker x:Name="HasarTarihiPicker"
                                        Format="dd.MM.yyyy"
                                        TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="Tahmini Maliyet (TL)" FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                        <Border HeightRequest="52" Padding="15,0" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Entry x:Name="MaliyetEntry"
                                   Placeholder="0.00"
                                   Keyboard="Numeric"
                                   TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                                   PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Açıklama -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Hasar Detayları / Notlar" FontSize="12"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                    <Border HeightRequest="110" Padding="15,10" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Editor x:Name="AciklamaEditor"
                                Placeholder="Hasar nasıl oluştu, hangi parçalar etkilendi..."
                                TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                                PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
                                AutoSize="TextChanges"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Kaydet Butonu -->
                <Button Text="HASARI KAYDET"
                        BackgroundColor="#EF4444"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="55"
                        Margin="0,15,0,30"
                        Clicked="OnHasarKaydetClicked"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
