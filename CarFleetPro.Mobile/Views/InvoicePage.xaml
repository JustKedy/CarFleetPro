<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.InvoicePage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, Auto, *, 75">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="ÖDEMELER VE FATURALAR" FontSize="20" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Padding="20,15" ColumnSpacing="10">
            <Border Grid.Column="0" Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" HeightRequest="50">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Entry Placeholder="Sözleşme No veya İsim Ara..." TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" Margin="15,0" VerticalOptions="Center" />
            </Border>
            <Button Grid.Column="1" Text="TÜMÜ" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" Padding="15,0"/>
        </Grid>

        <CollectionView x:Name="InvoiceList" Grid.Row="2" Margin="20,0" VerticalScrollBarVisibility="Never" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Margin="0,5" Padding="15" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05"/>
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, Auto" RowSpacing="10">
                            <!-- Başlık Satırı -->
                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding InvoiceId, StringFormat='Fatura No: INV-{0}'}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" FontSize="14" />
                                    <Label Text="{Binding CustomerName, StringFormat='Müşteri: {0}'}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" BackgroundColor="#D1FAE5" Padding="10,5" StrokeThickness="0" VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Status}" TextColor="#065F46" FontSize="10" FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                            
                            <!-- Detay Satırı -->
                            <Grid Grid.Row="1" ColumnDefinitions="*, Auto" VerticalOptions="End">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding IssuedAt, StringFormat='Tarih: {0:dd.MM.yyyy}'}" FontSize="11" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" />
                                    <Label Text="{Binding Amount, StringFormat='Tutar: {0:N2} TL'}" FontSize="14" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" FontAttributes="Bold" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="EKSTRE GÖRÜNTÜLE (PDF)" Clicked="OnDownloadPdfClicked" CommandParameter="{Binding .}" BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}" TextColor="#3B82F6" FontSize="10" FontAttributes="Bold" HeightRequest="30" Padding="10,0" CornerRadius="6" VerticalOptions="End"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <controls:BottomNavBar Grid.Row="3" SelectedTab="Home" />

    </Grid>
</ContentPage>
