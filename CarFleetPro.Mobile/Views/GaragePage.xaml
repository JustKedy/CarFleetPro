<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             xmlns:vm="clr-namespace:CarFleetPro.Mobile.ViewModels"
             xmlns:models="clr-namespace:CarFleetPro.Mobile.Models"
             x:DataType="vm:GarageViewModel"
             x:Class="CarFleetPro.Mobile.Views.GaragePage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ─── HEADER ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0" HeightRequest="110">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold"/>
                    <Label Text="PRO"      FontSize="14" TextColor="#3B82F6" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Text="ANA SAYFA" FontSize="26" TextColor="White"
                       HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <!-- ─── ORTA ALAN (Skeleton veya Gerçek Liste) ─────────────── -->
        <Grid Grid.Row="1">

            <!-- ═══════════════════════════════════════════════════════
                 GERÇEK İÇERİK  (IsLoading=false olunca görünür)
            ════════════════════════════════════════════════════════════ -->
            <CollectionView
                Margin="0,10,0,0"
                SelectionMode="None"
                ItemsSource="{Binding AracListesi}"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

                <CollectionView.Footer>
                    <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <!-- DataTemplate içi için x:DataType burada Vehicle'a alınır -->
                    <DataTemplate x:DataType="models:Vehicle">
                        <Border BackgroundColor="White"
                                Padding="10" Margin="20,10,20,10"
                                Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="10">

                                <!-- Araç Resmi -->
                                <Border Padding="0" Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="White">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Image Source="{Binding ResimUrl}"
                                           HeightRequest="150"
                                           Aspect="AspectFit"
                                           Margin="10"/>
                                </Border>

                                <!-- Durum satırı  -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="5,0" Margin="0,5">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GarageViewModel}}, Path=DetayAcKapaCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                        <Ellipse WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                            <Ellipse.Triggers>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="MÜSAİT">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="DOLU">
                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="BAKIMDA">
                                                    <Setter Property="Fill" Value="#F59E0B"/>
                                                </DataTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <Label Text="{Binding Durum}" TextColor="#1F2937"
                                               FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <Image Grid.Column="2" Source="arrowdown.svg"
                                           HeightRequest="20" WidthRequest="20"
                                           VerticalOptions="Center" HorizontalOptions="End">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Rotation" Value="180"/>
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Grid>

                                <!-- Detay paneli (akordeon) -->
                                <Border Padding="15" Stroke="#D1D5DB" StrokeThickness="1"
                                        BackgroundColor="White"
                                        IsVisible="{Binding IsExpanded}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,*" RowSpacing="5">
                                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                                            <Label Text="{Binding KiralayanKisi,   StringFormat='Kiralayan: {0}',        TargetNullValue='Kiralayan: Yok'}"  FontSize="12" TextColor="#4B5563"/>
                                            <Label Text="{Binding KiralamaFiyati,  StringFormat='Kiralama Fiyatı: {0}TL', TargetNullValue='Kiralama Fiyatı: -'}" FontSize="12" TextColor="#4B5563"/>
                                            <Label Text="{Binding KiralamaSuresi,  StringFormat='Kiralama Süresi: {0}',  TargetNullValue='Kiralama Süresi: -'}" FontSize="12" TextColor="#4B5563"/>
                                            <Label Text="{Binding KiralamaTarihi,  StringFormat='Kiralama Tarihi: {0}',  TargetNullValue='Kiralama Tarihi: -'}" FontSize="12" TextColor="#4B5563"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                                            <Label Text="{Binding Plaka, StringFormat='Araç Plakası: {0}'}" FontSize="12" TextColor="#4B5563" HorizontalOptions="End"/>
                                            <Label Text="{Binding Marka, StringFormat='Araç Marka: {0}'}"  FontSize="12" TextColor="#4B5563" HorizontalOptions="End"/>
                                            <Label Text="{Binding Model, StringFormat='Araç Model: {0}'}"  FontSize="12" TextColor="#3B82F6" FontAttributes="Bold" HorizontalOptions="End"/>
                                            <Label Text="{Binding Hp,    StringFormat='Araç Hp: {0}'}"     FontSize="12" TextColor="#4B5563" HorizontalOptions="End"/>
                                            <Label Text="{Binding Yas,   StringFormat='Araç Yaşı: {0}'}"   FontSize="12" TextColor="#4B5563" HorizontalOptions="End"/>
                                            <Label Text="{Binding Km,    StringFormat='Araç KM: {0}'}"     FontSize="12" TextColor="#4B5563" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ═══════════════════════════════════════════════════════
                 İSKELET EKRAN  (IsLoading=true iken görünür)
                 3 adet araç kartı taklidi
            ════════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Padding="20,10,20,20" Spacing="15"
                                 IsVisible="{Binding IsLoading}">

                <!-- İskelet Kart Tekrarlı (3 adet) -->
                <Border BackgroundColor="White" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="#E5E7EB" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="#E5E7EB" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="#E5E7EB" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="#E5E7EB" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="#E5E7EB" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="#E5E7EB" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </Grid>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="Garage"/>

    </Grid>
</ContentPage>