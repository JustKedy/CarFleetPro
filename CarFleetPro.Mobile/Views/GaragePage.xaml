<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             xmlns:vm="clr-namespace:CarFleetPro.Mobile.ViewModels"
             xmlns:models="clr-namespace:CarFleetPro.Mobile.Models"
             x:DataType="vm:GarageViewModel"
             x:Class="CarFleetPro.Mobile.Views.GaragePage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0" HeightRequest="110">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold"/>
                    <Label Text="PRO"      FontSize="14" TextColor="#3B82F6" FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <Label Text="ANA SAYFA" FontSize="26" TextColor="White"
                       HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        
        <Grid Grid.Row="1" RowDefinitions="Auto, *">

            <!-- Filter Chips -->
            <ScrollView Grid.Row="0" HorizontalOptions="Fill" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="20,15,20,5">
                <HorizontalStackLayout Spacing="10">
                    <!-- Tümü -->
                    <Border StrokeThickness="0" HeightRequest="38" Padding="15,0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsTumuSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#3B82F6"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsTumuSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E5E7EB, Dark=#1E293B}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="Tümü"/>
                        </Border.GestureRecognizers>
                        <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                        <Label Text="Tümü" VerticalOptions="Center" FontAttributes="Bold" FontSize="13">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsTumuSelected}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsTumuSelected}" Value="False">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#4B5563, Dark=#94A3B8}"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <!-- Müsait -->
                    <Border StrokeThickness="1" Stroke="#10B981" HeightRequest="38" Padding="15,0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsMusaitSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#10B981"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsMusaitSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="Müsait"/>
                        </Border.GestureRecognizers>
                        <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Ellipse WidthRequest="8" HeightRequest="8">
                                <Ellipse.Triggers>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsMusaitSelected}" Value="True">
                                        <Setter Property="Fill" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsMusaitSelected}" Value="False">
                                        <Setter Property="Fill" Value="#10B981"/>
                                    </DataTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Label Text="Müsait" FontSize="13">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsMusaitSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsMusaitSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Dolu -->
                    <Border StrokeThickness="1" Stroke="#EF4444" HeightRequest="38" Padding="15,0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsDoluSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#EF4444"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsDoluSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="Dolu"/>
                        </Border.GestureRecognizers>
                        <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Ellipse WidthRequest="8" HeightRequest="8">
                                <Ellipse.Triggers>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsDoluSelected}" Value="True">
                                        <Setter Property="Fill" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsDoluSelected}" Value="False">
                                        <Setter Property="Fill" Value="#EF4444"/>
                                    </DataTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Label Text="Dolu" FontSize="13">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsDoluSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsDoluSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Bakımda -->
                    <Border StrokeThickness="1" Stroke="#F59E0B" HeightRequest="38" Padding="15,0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsBakimdaSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#F59E0B"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsBakimdaSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FiltreleCommand}" CommandParameter="Bakımda"/>
                        </Border.GestureRecognizers>
                        <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Ellipse WidthRequest="8" HeightRequest="8">
                                <Ellipse.Triggers>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsBakimdaSelected}" Value="True">
                                        <Setter Property="Fill" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsBakimdaSelected}" Value="False">
                                        <Setter Property="Fill" Value="#F59E0B"/>
                                    </DataTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Label Text="Bakımda" FontSize="13">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsBakimdaSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsBakimdaSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>


            <CollectionView Grid.Row="1"
                Margin="0,10,0,0"
                SelectionMode="None"
                ItemsSource="{Binding AracListesi}"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

                <CollectionView.Footer>
                    <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    
                    <DataTemplate x:DataType="models:Vehicle">
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                Padding="10" Margin="20,10,20,10"
                                Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="10">

                                
                                <Border Padding="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HeightRequest="180">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Image Source="{Binding ResimUrl}"
                                           Aspect="AspectFill"
                                           VerticalOptions="Fill" HorizontalOptions="Fill" />
                                </Border>

                                
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="5,0" Margin="0,5">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAracTapped" />
                                    </Grid.GestureRecognizers>

                                    <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                        <Ellipse WidthRequest="16" HeightRequest="16" VerticalOptions="Center">
                                            <Ellipse.Triggers>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="MÜSAİT">
                                                     <Setter Property="Fill" Value="#10B981"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="Müsait">
                                                     <Setter Property="Fill" Value="#10B981"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="müsait">
                                                     <Setter Property="Fill" Value="#10B981"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="DOLU">
                                                     <Setter Property="Fill" Value="#EF4444"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="Dolu">
                                                     <Setter Property="Fill" Value="#EF4444"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="BAKIMDA">
                                                     <Setter Property="Fill" Value="#F59E0B"/>
                                                 </DataTrigger>
                                                 <DataTrigger TargetType="Ellipse" Binding="{Binding Durum}" Value="Bakımda">
                                                     <Setter Property="Fill" Value="#F59E0B"/>
                                                 </DataTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                         <Label Text="{Binding Plaka}" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}"
                                                FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <Image Grid.Column="2" Source="arrowdown.svg"
                                           HeightRequest="20" WidthRequest="20"
                                           VerticalOptions="Center" HorizontalOptions="End">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Rotation" Value="180"/>
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Grid>

                                
                                <Border Padding="15" Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}" StrokeThickness="1"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                        IsVisible="{Binding IsExpanded}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="15">
                                        <Grid ColumnDefinitions="*,*" RowSpacing="5">
                                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                                <Label Text="{Binding Durum}"  FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                                 <Label Text="{Binding Marka, StringFormat='{0} '}" FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                                 <Label Text="{Binding Model}" FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                                <Label Text="{Binding KiralayanKisi,   StringFormat='Kiralayan: {0}',        TargetNullValue='Kiralayan: Yok'}" FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                                <Label Text="{Binding KiralamaFiyati,  StringFormat='Kiralama Fiyatı: {0}TL', TargetNullValue='Kiralama Fiyatı: -'}" FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}"/>
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                                <Label Text="{Binding KiralamaSuresi,  StringFormat='Kiralama Süresi: {0}',  TargetNullValue='Kiralama Süresi: -'}" FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" HorizontalOptions="End"/>
                                                <Label Text="{Binding KiralamaTarihi,  StringFormat='Kiralama Tarihi: {0}',  TargetNullValue='Kiralama Tarihi: -'}"  FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" HorizontalOptions="End"/>
                                                <Label Text="{Binding Plaka, StringFormat='Araç Plakası: {0}'}"  FontSize="12" TextColor="#3B82F6" FontAttributes="Bold" HorizontalOptions="End"/>
                                                <Label Text="{Binding Marka, StringFormat='Araç Marka: {0}'}"     FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" HorizontalOptions="End"/>
                                                <Label Text="{Binding Model, StringFormat='Araç Model: {0}'}"   FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" HorizontalOptions="End"/>
                                                <Label Text="{Binding Hp,    StringFormat='Araç Hp: {0}'}"     FontSize="12" TextColor="{AppThemeBinding Light=#4B5563, Dark=#CBD5E1}" HorizontalOptions="End"/>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                            <Button Text="KİRALA" 
                                                    Clicked="OnKiralaClicked"
                                                    BackgroundColor="#3B82F6"
                                                    TextColor="White"
                                                    FontAttributes="Bold"
                                                    CornerRadius="8"
                                                    HeightRequest="40"
                                                    Padding="15,0"/>
                                            <Button Text="BAKIM" 
                                                    Clicked="OnBakimClicked"
                                                    BackgroundColor="#F59E0B"
                                                    TextColor="White"
                                                    FontAttributes="Bold"
                                                    CornerRadius="8"
                                                    HeightRequest="40"
                                                    Padding="15,0"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            
            <VerticalStackLayout Padding="20,10,20,20" Spacing="15"
                                 IsVisible="{Binding IsLoading}">

                
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="14" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="150" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" CornerRadius="10"/>
                        <BoxView HeightRequest="14" WidthRequest="100" BackgroundColor="#D1D5DB" HorizontalOptions="Start" CornerRadius="6"/>
                        <BoxView HeightRequest="12" WidthRequest="160" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" HorizontalOptions="Start" CornerRadius="6"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </Grid>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="Garage"/>

    </Grid>
</ContentPage>