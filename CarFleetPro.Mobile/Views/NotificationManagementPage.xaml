<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.NotificationManagementPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, *">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="BİLDİRİM GÖNDER" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <Label Text="Yeni Bildirim (Push / SMS)" FontSize="18" TextColor="#1F2937" FontAttributes="Bold"/>

                <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Gönderilecek Kişiler" TextColor="#6B7280" FontSize="12"/>
                            <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Picker x:Name="TargetAudiencePicker" Title="Hedef Kitle Seçin" TextColor="#1F2937">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Tüm Müşteriler</x:String>
                                            <x:String>Aktif Kiradaki Müşteriler</x:String>
                                            <x:String>Sadece Personel</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Bildirim Başlığı" TextColor="#6B7280" FontSize="12"/>
                            <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="Örn: Kampanya Duyurusu" TextColor="#1F2937"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Mesaj İçeriği" TextColor="#6B7280" FontSize="12"/>
                            <Border HeightRequest="120" Padding="15" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Editor Placeholder="Mesajınızı buraya yazın..." TextColor="#1F2937"/>
                            </Border>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <CheckBox x:Name="SendSmsCheckbox" Color="#3B82F6"/>
                            <Label Text="Ayrıca SMS olarak gönder" TextColor="#1F2937" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Button Text="BİLDİRİMİ GÖNDER" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="55" Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
