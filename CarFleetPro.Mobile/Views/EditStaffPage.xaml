<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.EditStaffPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="110, *">
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="ÇALIŞAN YÖNETİMİ" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="20" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="PERSONEL DÜZENLE" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" Margin="0,0,0,5"/>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="Yönetici Yetkisi Ver" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" VerticalOptions="Center" />
                                <Switch x:Name="AdminRoleSwitch" Grid.Column="1" OnColor="#3B82F6" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="AdminNameEntry" Placeholder="Ad Soyad" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>
                        
                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="AdminEmailEntry" IsEnabled="False" Placeholder="E-Posta (Değiştirilemez)" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="AdminPhoneEntry" Placeholder="Telefon (Örn: 0555...)" Keyboard="Telephone" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <Button Text="BİLGİLERİ GÜNCELLE" Clicked="OnUpdateStaffClicked" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="55" Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
