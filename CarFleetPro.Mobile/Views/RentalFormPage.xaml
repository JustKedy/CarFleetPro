<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.RentalFormPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0" Padding="20,10,20,30">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30"/>
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto, Auto">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" HeightRequest="50">
                    <ImageButton Grid.Column="0" Source="arrow_back_white.svg" Clicked="OnBackClicked" BackgroundColor="Transparent" WidthRequest="30" HeightRequest="30"/>
                    <Label Grid.Column="1" Text="ARAÇ KİRALAMA" FontAttributes="Bold" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Image Grid.Column="2" Source="notification_bell_white.svg" HeightRequest="25" WidthRequest="25"/>
                </Grid>

                <VerticalStackLayout Grid.Row="1" Spacing="5" Margin="0,15,0,0">
                    <Label Text="NISSAN QASHQAI" TextColor="White" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="55 BFR 051 | 2023 | DİZEL | OTOMATİK" TextColor="White" FontSize="14" HorizontalOptions="Center" Opacity="0.8"/>

                    <Image Source="car_placeholder.png" Aspect="AspectFit" HeightRequest="140" HorizontalOptions="Center" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Label Text="Müşteri Bilgileri" FontSize="18" TextColor="#1F2937" FontAttributes="Bold"/>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Kayıtlı Müşteri Seçin" TextColor="#6B7280" FontSize="12"/>
                    <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Picker x:Name="MusteriPicker" Title="Müşteri Seçiniz" TextColor="#1F2937"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Adı Soyadı" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Ad Soyad" TextColor="#1F2937"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="T.C. Kimlik" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="11 Haneli No" Keyboard="Numeric" TextColor="#1F2937"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Kiralama Detayları" FontSize="18" TextColor="#1F2937" FontAttributes="Bold" Margin="0,10,0,0"/>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Araç Seçimi" TextColor="#6B7280" FontSize="12"/>
                    <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Picker x:Name="AracPicker" Title="Müsait Araç Seçiniz" TextColor="#1F2937"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Teslim Tarihi" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="10,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <DatePicker Format="dd.MM.yyyy" TextColor="#1F2937"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="Dönüş Tarihi" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="10,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <DatePicker Format="dd.MM.yyyy" TextColor="#1F2937"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Günlük Ücret (TL)" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry x:Name="GunlukUcretEntry" Placeholder="0.00" Keyboard="Numeric" TextColor="#1F2937" IsEnabled="False"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="Depozito (TL)" TextColor="#6B7280" FontSize="12"/>
                        <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry x:Name="DepozitoEntry" Placeholder="Örn: 2000" Keyboard="Numeric" TextColor="#1F2937"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Toplam Tutar (TL)" TextColor="#6B7280" FontSize="12"/>
                    <Border HeightRequest="50" Padding="15,0" StrokeThickness="1" Stroke="#3B82F6" BackgroundColor="#EFF6FF">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label x:Name="ToplamTutarLabel" Text="0.00 TL" TextColor="#3B82F6" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Kiralama Notları" TextColor="#6B7280" FontSize="12"/>
                    <Border HeightRequest="100" Padding="15" StrokeThickness="1" Stroke="#D1D5DB" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Editor Placeholder="Özel notlar..." TextColor="#1F2937"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="KİRALAMAYI TAMAMLA" 
                        BackgroundColor="#3B82F6" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        CornerRadius="12" 
                        HeightRequest="55" 
                        Margin="0,20,0,30"
                        Clicked="OnCompleteRentalClicked"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>