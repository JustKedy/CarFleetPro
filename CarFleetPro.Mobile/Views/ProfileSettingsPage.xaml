<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarFleetPro.Mobile.Views.ProfileSettingsPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="110, *">
        
        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="PROFİL AYARLARI" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="15">
                
                
                <VerticalStackLayout HorizontalOptions="Center" Margin="0,10,0,10">
                    <Grid WidthRequest="100" HeightRequest="100">
                        <Border WidthRequest="100" HeightRequest="100" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50" />
                            </Border.StrokeShape>
                            <Image Source="{AppThemeBinding Light=user_black.svg, Dark=user_white.svg}" HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.5"/>
                        </Border>
                        
                        
                        <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#3B82F6" StrokeThickness="2" Stroke="White" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Image Source="edit.svg" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="20" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Kişisel Bilgiler" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" Margin="0,0,0,5"/>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="NameEntry" Placeholder="Ad Soyad" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="EmailEntry" Placeholder="E-Posta" Keyboard="Email" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#263347}" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="PhoneEntry" Placeholder="Telefon" Keyboard="Telephone" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15" StrokeThickness="0" Margin="0,0,0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>
                    
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangePasswordTapped" />
                        </Grid.GestureRecognizers>
                        
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}" StrokeThickness="0" VerticalOptions="Center" HorizontalOptions="Center">
                             <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Image Source="{AppThemeBinding Light=lock_black.svg, Dark=lock_white.svg}" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <Label Grid.Column="1" Text="Şifre Değiştir" Margin="15,0,0,0" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Image Grid.Column="2" Source="{AppThemeBinding Light=arrow_right_black.svg, Dark=arrow_right_white.svg}" HeightRequest="16" WidthRequest="16" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Button Text="PROFİLİ GÜNCELLE" Clicked="OnUpdateProfileClicked" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="55" Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
