<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.CustomersPage"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, Auto, *, 75">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="30, *, 30" Padding="20,0">
                <ImageButton Grid.Column="0" Source="arrow_left_white.svg" Clicked="OnBackClicked" HeightRequest="25" WidthRequest="25" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                        <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                        <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Text="MÜŞTERİ YÖNETİMİ" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, 60" Padding="20,15" ColumnSpacing="10">
            <Border Grid.Column="0" Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#334155}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" HeightRequest="50">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Entry x:Name="SearchEntry" Placeholder="Müşteri Ara (İsim, TC, Tel)..." TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" Margin="15,0" VerticalOptions="Center" TextChanged="OnSearchTextChanged" />
            </Border>

            <Button Grid.Column="1" Text="+" BackgroundColor="#3B82F6" TextColor="White" FontSize="24" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" />
        </Grid>

        <CollectionView x:Name="CustomersList" Grid.Row="2" Margin="20,0" VerticalScrollBarVisibility="Never" SelectionMode="Single" SelectionChanged="OnCustomerSelected">
            <CollectionView.ItemsSource>
            </CollectionView.ItemsSource>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Margin="0,5" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Border Grid.Column="0" WidthRequest="45" HeightRequest="45" BackgroundColor="#DBEAFE" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22.5" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Initials}" TextColor="#1E40AF" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                <Label Text="{Binding FullName}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1F2937, Dark=#F1F5F9}" FontSize="16" />
                                <Label Text="{Binding PhoneNumber}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="{Binding RentalStatus}" TextColor="#10B981" FontSize="11" HorizontalOptions="End" FontAttributes="Bold" />
                                <Label Text="{Binding TotalRentals, StringFormat='Kiralama: {0}'}" FontSize="11" TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}" HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <controls:BottomNavBar Grid.Row="3" SelectedTab="Home" />

    </Grid>
</ContentPage>