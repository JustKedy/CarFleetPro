<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.SettingsPage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, *, 75">

        <Border Grid.Row="0"
                BackgroundColor="#0A1128" 
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>

            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                    <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Text="AYARLAR" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="0, 10, 0, 10">

                <Border BackgroundColor="White" Padding="15" Margin="20, 10, 20, 10" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="15">

                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" BackgroundColor="#F3F4F6" StrokeThickness="0" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="35" />
                                </Border.StrokeShape>
                                <Image Source="user_black.svg" HeightRequest="35" WidthRequest="35" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                <Label Text="Kadir Gürbüz" FontAttributes="Bold" FontSize="18" TextColor="#1F2937" />
                                <Label Text="Yetki: Sistem Yöneticisi" FontSize="12" TextColor="#6B7280" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,5" />

                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Border Grid.Column="0" WidthRequest="70" BackgroundColor="Transparent" StrokeThickness="0" VerticalOptions="Center">
                                <Image Source="lock_black.svg" HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <Label Grid.Column="1" Text="Şifre Değiştir" Margin="15,0,0,0" TextColor="#1F2937" FontSize="15" VerticalOptions="Center"/>
                            <Image Grid.Column="2" Source="arrow_right_black.svg" HeightRequest="16" WidthRequest="16" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="15" Margin="20, 10, 20, 10" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Bildirim Tercihleri" FontSize="14" FontAttributes="Bold" TextColor="#6B7280" Margin="0,0,0,10"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Bakım Yaklaşan Araç Bildirimleri" TextColor="#1F2937" FontSize="14" VerticalOptions="Center"/>
                            <Image Grid.Column="1" x:Name="MaintenanceNotifIcon" Source="bell_on_black.svg" HeightRequest="28" WidthRequest="28" VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,5,0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Kira Süresi Dolumu Bildirimleri" TextColor="#1F2937" FontSize="14" VerticalOptions="Center"/>
                            <Image Grid.Column="1" x:Name="RentalNotifIcon" Source="bell_on_black.svg" HeightRequest="28" WidthRequest="28" VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,5,0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Boşa Çıkan Araç Bildirimleri" TextColor="#1F2937" FontSize="14" VerticalOptions="Center"/>
                            <Image Grid.Column="1" x:Name="AvailableNotifIcon" Source="bell_off_black.svg" HeightRequest="28" WidthRequest="28" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="15" Margin="20, 10, 20, 10" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Grid.Column="0" WidthRequest="70" BackgroundColor="Transparent" StrokeThickness="0" VerticalOptions="Center">
                            <Image Source="sun_black.svg" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <Label Grid.Column="1" Text="Uygulama Teması" Margin="15,0,0,0" TextColor="#1F2937" FontSize="14" VerticalOptions="Center"/>

                        <Border Grid.Column="2" BackgroundColor="#F3F4F6" StrokeThickness="0" Padding="10, 5" HeightRequest="35">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="Açık Tema" FontSize="12" TextColor="#1F2937" VerticalOptions="Center"/>
                                <Image Source="arrow_right_black.svg" HeightRequest="10" WidthRequest="10" VerticalOptions="Center" Rotation="90"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <VerticalStackLayout Margin="20, 20, 20, 10" Spacing="15">
                    <Border BackgroundColor="#EF4444" StrokeThickness="0" HeightRequest="55" Padding="20,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *">
                            <Image Grid.Column="0" Source="logout.svg" HeightRequest="24" WidthRequest="24" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="ÇIKIŞ YAP" FontAttributes="Bold" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" Margin="-24,0,0,0"/>
                        </Grid>
                    </Border>

                    <Label Text="CarFleetPro v1.0.0" FontSize="12" TextColor="#9CA3AF" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="Settings" />

    </Grid>
</ContentPage>