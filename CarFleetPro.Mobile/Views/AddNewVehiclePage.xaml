<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CarFleetPro.Mobile.Controls"
             x:Class="CarFleetPro.Mobile.Views.AddNewVehiclePage"
             BackgroundColor="#F3F4F6"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="110, *, 75">

        <Border Grid.Row="0" BackgroundColor="#0A1128" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0, 0, 20, 20" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Label Text="CARFLEET" FontSize="14" TextColor="White" FontAttributes="Bold" />
                    <Label Text="PRO" FontSize="14" TextColor="#3B82F6" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Text="YENİ ARAÇ EKLE" FontSize="26" TextColor="White" HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="0, 10, 0, 20" Spacing="15">

                <Border BackgroundColor="White" Padding="20" Margin="20, 10, 20, 0" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Border BackgroundColor="#F3F4F6" HeightRequest="120" WidthRequest="200" Stroke="#D1D5DB" StrokeThickness="2" StrokeDashArray="5,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                                <Image Source="car.svg" HeightRequest="40" WidthRequest="40" Opacity="0.5" />
                                <Label Text="Görsel Yüklemek İçin Tıklayın" FontSize="12" TextColor="#6B7280" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Padding="20" Margin="20, 0, 20, 0" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Araç Detayları" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" Margin="0,0,0,5"/>

                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry Placeholder="Araç Plakası (Örn: 34 ABC 123)" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent" />
                        </Border>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Border Grid.Column="0" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="Marka" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                            <Border Grid.Column="1" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="Model" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Border Grid.Column="0" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="Yıl" Keyboard="Numeric" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                            <Border Grid.Column="1" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="Renk" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Border Grid.Column="0" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="KM" Keyboard="Numeric" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                            <Border Grid.Column="1" Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Placeholder="Motor Gücü (HP)" Keyboard="Numeric" TextColor="#1F2937" PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0" HeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Picker Title="Mevcut Durum Seçin" TextColor="#1F2937" TitleColor="#9CA3AF" BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Müsait</x:String>
                                    <x:String>Dolu</x:String>
                                    <x:String>Bakımda</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="20, 10, 20, 10">
                    <Button Grid.Column="0" Text="İPTAL ET" Clicked="OnCancelClicked" BackgroundColor="White" TextColor="#EF4444" BorderColor="#EF4444" BorderWidth="1" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" />
                    <Button Grid.Column="1" Text="KAYDET" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavBar Grid.Row="2" SelectedTab="List" />

    </Grid>
</ContentPage>  